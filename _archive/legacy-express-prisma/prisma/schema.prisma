generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CooperativeStatus {
  ACTIVE
  ONBOARDING
  SUSPENDED
}

enum UserRole {
  ADMIN
  MANAGER
  AGENT
  MEMBER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum MembreStatut {
  ACTIF
  INACTIF
  SAISONNIER
}

enum CollecteStatut {
  VALIDE
  EN_ATTENTE
}

enum LotStatut {
  ACTIF
  TERMINE
}

enum EtapeStatut {
  EN_COURS
  TERMINE
}

enum FluxType {
  PRE_RECOLTE
  POST_RECOLTE
}

enum FactureStatut {
  EN_ATTENTE
  ENCAISSEE
}

enum TacheStatut {
  A_FAIRE
  EN_COURS
  TERMINEE
}

enum TachePriorite {
  BASSE
  MOYENNE
  HAUTE
}

enum RecommandationStatut {
  STABLE
  CRITIQUE
  ATTENTION
}

model Cooperative {
  id          String            @id @default(uuid())
  name        String
  region      String
  mode        String            @default("operationnel")
  address     String?
  phone       String?
  status      CooperativeStatus @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  users            User[]
  membres          Membre[]
  produits         Produit[]
  parcelles        Parcelle[]
  collectes        Collecte[]
  stocks           Stock[]
  lots             Lot[]
  tresorerie       Tresorerie[]
  factures         Facture[]
  taches           Tache[]
  evenements       EvenementCalendrier[]
  recommandations  RecommandationIA[]

  @@index([region])
  @@index([status])
}

model User {
  id             String     @id @default(uuid())
  fullName       String
  email          String     @unique
  phone          String?
  passwordHash   String
  role           UserRole
  status         UserStatus @default(ACTIVE)
  cooperativeId  String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  cooperative    Cooperative? @relation(fields: [cooperativeId], references: [id], onDelete: SetNull)
  collectesAgent Collecte[]   @relation("CollecteAgent")
  assignedTaches Tache[]      @relation("TacheAssignee")
  createdLots    Lot[]        @relation("LotCreatedBy")

  @@index([cooperativeId])
  @@index([role])
  @@index([status])
}

model Membre {
  id                 String       @id @default(uuid())
  cooperativeId      String
  code               String       @unique
  nom                String
  prenom             String
  fullName           String
  phone              String
  village            String?
  culturePrincipale  String?
  mainProduct        String?
  parcelCount        Int          @default(0)
  areaHectares       Float        @default(0)
  joinDate           DateTime?
  specialty          String?
  statut             MembreStatut @default(ACTIF)
  deletedAt          DateTime?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  cooperative        Cooperative  @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  collectes          Collecte[]
  factures           Facture[]
  parcelles          Parcelle[]

  @@index([cooperativeId])
  @@index([statut])
  @@index([joinDate])
}

model Produit {
  id             String      @id @default(uuid())
  cooperativeId  String
  name           String
  category       String
  unit           String      @default("kg")
  qualityGrade   String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  cooperative    Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  collectes      Collecte[]
  stocks         Stock[]
  lots           Lot[]

  @@unique([cooperativeId, name])
  @@index([cooperativeId])
}

model Parcelle {
  id              String      @id @default(uuid())
  memberId        String
  cooperativeId   String
  location        String
  area            Float
  soilType        String?
  irrigationType  String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  membre          Membre      @relation(fields: [memberId], references: [id], onDelete: Cascade)
  cooperative     Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([cooperativeId])
}

model Collecte {
  id                String         @id @default(uuid())
  cooperativeId     String
  membreId          String
  produitId         String?
  produit           String
  quantiteKg        Float
  statut            CollecteStatut
  date              DateTime
  agentId           String?
  grade             String         @default("A")
  estimatedValueFcfa Int?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  cooperative       Cooperative    @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  membre            Membre         @relation(fields: [membreId], references: [id], onDelete: Cascade)
  agent             User?          @relation("CollecteAgent", fields: [agentId], references: [id], onDelete: SetNull)
  produitRef        Produit?       @relation(fields: [produitId], references: [id], onDelete: SetNull)

  @@index([cooperativeId])
  @@index([date])
  @@index([statut])
  @@index([produit])
}

model Stock {
  id                  String      @id @default(uuid())
  cooperativeId       String
  produitId           String?
  produit             String
  quantiteActuelleKg  Float
  seuilCritiqueKg     Float
  quantiteMaxKg       Float
  unit                String      @default("kg")
  lastUpdated         DateTime    @default(now())
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  cooperative         Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  produitRef          Produit?    @relation(fields: [produitId], references: [id], onDelete: SetNull)

  @@index([cooperativeId])
  @@index([produit])
}

model Lot {
  id                 String      @id @default(uuid())
  cooperativeId      String
  productId          String?
  code               String      @unique
  produit            String
  quantiteInitialeKg Float
  quantiteActuelleKg Float
  statut             LotStatut   @default(ACTIF)
  creationDate       DateTime
  createdByUserId    String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  cooperative        Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  product            Produit?    @relation(fields: [productId], references: [id], onDelete: SetNull)
  createdBy          User?       @relation("LotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  etapes             EtapeLot[]
  fluxMatieres       FluxMatiere[]
  recommandations    RecommandationIA[]

  @@index([cooperativeId])
  @@index([statut])
  @@index([creationDate])
}

model EtapeLot {
  id                 String      @id @default(uuid())
  lotId              String
  nomEtape           String
  type               String
  ordre              Int
  quantiteEntreeKg   Float
  quantiteSortieKg   Float
  perteKg            Float
  statut             EtapeStatut @default(EN_COURS)
  dateDebut          DateTime
  dateFin            DateTime?
  notes              String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  lot                Lot         @relation(fields: [lotId], references: [id], onDelete: Cascade)
  fluxMatieres       FluxMatiere[]

  @@unique([lotId, ordre])
  @@index([lotId])
  @@index([statut])
  @@index([dateDebut])
}

model FluxMatiere {
  id          String    @id @default(uuid())
  lotId       String
  etapeId     String?
  type        FluxType
  date        DateTime
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lot         Lot       @relation(fields: [lotId], references: [id], onDelete: Cascade)
  etape       EtapeLot? @relation(fields: [etapeId], references: [id], onDelete: SetNull)

  @@index([lotId])
  @@index([date])
  @@index([type])
}

model Tresorerie {
  id            String      @id @default(uuid())
  cooperativeId String
  mois          Int
  annee         Int
  recettesFcfa  Int
  depensesFcfa  Int
  soldeFcfa     Int
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@unique([cooperativeId, mois, annee])
  @@index([cooperativeId])
  @@index([annee, mois])
}

model Facture {
  id            String        @id @default(uuid())
  cooperativeId String
  numero        String        @unique
  membreId      String
  montantFcfa   Int
  statut        FactureStatut
  dateEmission  DateTime
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cooperative   Cooperative   @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  membre        Membre        @relation(fields: [membreId], references: [id], onDelete: Cascade)

  @@index([cooperativeId])
  @@index([statut])
  @@index([dateEmission])
}

model Tache {
  id            String        @id @default(uuid())
  cooperativeId String
  titre         String
  description   String?
  assigneeId    String?
  statut        TacheStatut   @default(A_FAIRE)
  dueDate       DateTime?
  priorite      TachePriorite @default(MOYENNE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  cooperative   Cooperative   @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  assignee      User?         @relation("TacheAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([cooperativeId])
  @@index([statut])
  @@index([dueDate])
}

model EvenementCalendrier {
  id            String      @id @default(uuid())
  cooperativeId String
  titre         String
  date          DateTime
  type          String
  description   String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  cooperative   Cooperative @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)

  @@index([cooperativeId])
  @@index([date])
}

model RecommandationIA {
  id             String               @id @default(uuid())
  cooperativeId  String
  lotId          String?
  texte          String
  statut         RecommandationStatut @default(STABLE)
  impactedStep   String?
  rationale      String?
  expectedImpact String?
  generatedAt    DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  cooperative    Cooperative          @relation(fields: [cooperativeId], references: [id], onDelete: Cascade)
  lot            Lot?                 @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([cooperativeId])
  @@index([statut])
  @@index([generatedAt])
}

model ReferenceMetric {
  id        String   @id @default(uuid())
  sourceId  String
  country   String
  region    String
  crop      String
  metric    String
  period    String
  value     Float
  unit      String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([region])
  @@index([crop])
  @@index([metric])
}

model KnowledgeChunk {
  id        String   @id @default(uuid())
  sourceId  String
  sourceUrl String
  country   String
  region    String
  crop      String
  topic     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([region])
  @@index([crop])
  @@index([topic])
}
